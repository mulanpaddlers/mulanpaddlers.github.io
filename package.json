{
  "name": "mulanpaddlers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build && rm -rf docs && cp -r dist/. docs",
    "publish": "next build && rm -rf docs/* && cp -r dist/. docs && cp docs/en.html docs/index.html && (lsof -ti :3000 | xargs kill -9 2>/dev/null; true) && npm run dev",
    "clean": "rm -rf dist docs",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "15.3.0",
    "next-intl": "^3.26.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
